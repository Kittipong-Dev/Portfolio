# Server-only secret for /studio access. Do not expose as NEXT_PUBLIC_*.
STUDIO_PASSWORD=replace-with-a-long-random-password

# Fine-grained GitHub token for MVP server-side PR creation.
# Restrict it to this repository and the minimum permissions needed for contents and pull requests.
GITHUB_TOKEN=github_pat_replace_me
GITHUB_REPOSITORY=owner/repository
GITHUB_BASE_BRANCH=main
